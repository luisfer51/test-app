pipeline {
    agent any

    stages {
        stage('Environment Check') {
            steps {
                sh 'docker --version || true'
                sh 'gcloud --version || true'
                sh 'which docker || true'
                sh 'which gcloud || true'
            }
        }
        stage('Workspace Check') {
            steps {
                sh 'pwd'
                sh 'ls -la'
            }
        }
        stage('Execute Unit Tests') {
            parallel {
                stage('Unit Tests - Backend') {
                    agent {
                        docker {
                            image 'snakee/golang-junit:1.21'
                            reuseNode true
                            args '-v /var/jenkins_home:/var/jenkins_home -e GOPATH=/var/jenkins_home/go -e GOCACHE=/var/jenkins_home/.cache/go-build'
                        }
                    }
                    steps {
                        dir('bugtracker-backend') {
                            // sh 'go test -v ./... 2>&1 | go-junit-report > test-results.xml'
                            sh '''
                                go test -v ./... 2>&1 | go-junit-report > test-results.xml
                                
                                #Generate coverage report
                                go test -coverprofile=coverage.out -covermode=atomic ./...  
                                go tool cover -html=coverage.out -o coverage.html

                                mkdir -p reports
                                mv coverage.html reports/
                            '''                       
                        }
                    }
                    post {
                        always {
                            junit 'bugtracker-backend/test-results.xml'
                            publishHTML(target: [
                                reportDir: 'bugtracker-backend/reports',
                                reportFiles: 'coverage.html',
                                reportName: 'Backend Coverage Report'
                            ])    
                        }
                    }
                }
                stage('Unit Tests - Frontend') {
                    agent {
                        docker {
                            image 'node:20-alpine'
                            reuseNode true
                            args '-v /var/jenkins_home:/var/jenkins_home'
                        }
                    }
                    steps {
                        dir('bugtracker-frontend') {
                            sh '''
                                npm ci
                                npm test
                                mkdir -p reports
                                mv coverage reports/
                            '''
                        }
                    }
                    post {
                        always {
                            junit 'bugtracker-frontend/test-results.xml'
                            publishHTML(target: [
                                reportDir: 'bugtracker-frontend/reports/coverage',
                                reportFiles: 'index.html',
                                reportName: 'Frontend Coverage Report'
                            ])
                        }
                    }
                }
            }
        }
        stage('Launch Application') {
            agent {
                docker {
                    image 'docker:27.5.1'
                    reuseNode true
                    args '-v /var/run/docker.sock:/var/run/docker.sock -u 0'
                }
            }
            steps {
                sh 'docker compose up -d'
            }
        }
        stage('API Tests') {
            agent {
                docker {
                    image 'mcr.microsoft.com/playwright:v1.50.0-jammy'
                    reuseNode true
                    args '-u 0 --network=host'
                }
            }
            steps {
                dir('tests-api') {
                    sh '''
                        npx wait-port http://localhost:8080/api/health -t 30000
                        npm ci
                        npx playwright test
                    '''
                }
            }
            post {
                always {
                    junit 'tests-api/test-results/results.xml'
                    publishHTML(target: [
                        reportDir: 'tests-api/playwright-report',
                        reportFiles: 'index.html',
                        reportName: 'Playwright API Test Report'
                    ])
                }
            }
        }
        stage('E2E Tests') {
            agent {
                docker {
                    image 'mcr.microsoft.com/playwright:v1.50.0-jammy'
                    reuseNode true
                    args '-u 0 --network=host'
                }
            }
            steps {
                dir('tests-e2e') {
                    sh '''
                        npx wait-port http://localhost:3000/ -t 30000
                        npm ci
                        npx playwright test
                    '''
                }
            }
            post {
                always {
                    junit 'tests-e2e/test-results/results.xml'
                    publishHTML(target: [
                        reportDir: 'tests-e2e/playwright-report',
                        reportFiles: 'index.html',
                        reportName: 'Playwright E2E Test Report'
                    ])
                }
            }
        }
        stage('Performance Tests') {
            agent {
                docker {
                    image 'grafana/k6:latest'
                    reuseNode true
                    args '-u 0 --network=host --entrypoint=""'
                }
            }
            steps {
                dir('tests-perf') {
                    sh '''
                        k6 run script.js
                    '''
                }
            }
            post {
                always {
                    publishHTML(target: [
                        reportDir: 'tests-perf',
                        reportFiles: 'perf-results.html',
                        reportName: 'K6 Performance Test Report'
                    ])
                }
            }
        }
        stage('Build Backend Image') {
            steps {
                dir('bugtracker-backend') {
                    sh '''
                        docker build -t bugtracker-backend:test .
                    '''
                }
            }
        }
        stage('Push Backend Image') {
            steps {
                withCredentials([
                    file(
                        credentialsId: 'gcp-service-account',
                        variable: 'GCP_KEY'
                    )
                ]) {
                    sh '''
                        gcloud auth activate-service-account --key-file=$GCP_KEY

                        gcloud config set project bugtracker-demo

                        gcloud auth configure-docker southamerica-west1-docker.pkg.dev --quiet

                        docker tag \
                          bugtracker-backend:test \
                          southamerica-west1-docker.pkg.dev/bugtracker-demo/bugtracker-repo/backend:jenkins-test

                        docker push \
                          southamerica-west1-docker.pkg.dev/bugtracker-demo/bugtracker-repo/backend:jenkins-test
                    '''
                }
            }
        }
        stage('Deploy Backend') {
            steps {
                withCredentials([
                    file(
                        credentialsId: 'gcp-service-account',
                        variable: 'GCP_KEY'
                    )
                ]) {
                    sh '''
                        gcloud auth activate-service-account \
                        --key-file=$GCP_KEY

                        gcloud config set project bugtracker-demo

                        gcloud run deploy bugtracker-backend \
                        --image southamerica-west1-docker.pkg.dev/bugtracker-demo/bugtracker-repo/backend:jenkins-test \
                        --platform managed \
                        --region southamerica-west1 \
                        --allow-unauthenticated
                    '''
                }
            }
        }
        stage('Smoke Test Backend') {
            steps {
                sh '''
                    echo "Checking deployed backend..."

                    HTTP_CODE=$(curl --fail -s \
                        -o response.json \
                        -w "%{http_code}" \
                        https://bugtracker-backend-804706805992.southamerica-west1.run.app/api/health)

                    echo "HTTP Status: $HTTP_CODE"

                    cat response.json

                    test "$HTTP_CODE" = "200"

                    grep -qi '"status":"ok"' response.json
                '''
            }
        }
        stage('Build Frontend Image') {
            steps {
                dir('bugtracker-frontend') {
                    sh '''
                        docker build \
                        --build-arg NEXT_PUBLIC_API_URL=https://bugtracker-backend-804706805992.southamerica-west1.run.app \
                        -t bugtracker-frontend:test .
                    '''
                }
            }
        }
        stage('Push Frontend Image') {
            steps {
                withCredentials([
                    file(
                        credentialsId: 'gcp-service-account',
                        variable: 'GCP_KEY'
                    )
                ]) {
                    sh '''
                        gcloud auth activate-service-account --key-file=$GCP_KEY

                        gcloud config set project bugtracker-demo

                        gcloud auth configure-docker southamerica-west1-docker.pkg.dev --quiet

                        docker tag bugtracker-frontend:test \
                        southamerica-west1-docker.pkg.dev/bugtracker-demo/bugtracker-repo/frontend:jenkins-test

                        docker push \
                        southamerica-west1-docker.pkg.dev/bugtracker-demo/bugtracker-repo/frontend:jenkins-test
                    '''
                }
            }
        }
        stage('Deploy Frontend') {
            steps {
                withCredentials([
                    file(
                        credentialsId: 'gcp-service-account',
                        variable: 'GCP_KEY'
                    )
                ]) {
                    sh '''
                        gcloud auth activate-service-account \
                        --key-file=$GCP_KEY

                        gcloud config set project bugtracker-demo

                        gcloud run deploy bugtracker-frontend \
                        --image southamerica-west1-docker.pkg.dev/bugtracker-demo/bugtracker-repo/frontend:jenkins-test \
                        --platform managed \
                        --region southamerica-west1 \
                        --allow-unauthenticated
                    '''
                }
            }
        }
        stage('Smoke Test Frontend') {
            steps {
                sh '''
                    echo "Checking deployed frontend..."

                    HTTP_CODE=$(curl --fail -s \
                        -o frontend.html \
                        -w "%{http_code}" \
                        https://bugtracker-frontend-804706805992.southamerica-west1.run.app)

                    echo "HTTP Status: $HTTP_CODE"

                    test "$HTTP_CODE" = "200"

                    grep -qi "<html" frontend.html
                '''
            }
        }
    }
    post {
        always {
            cleanWs()
        }
    }
}